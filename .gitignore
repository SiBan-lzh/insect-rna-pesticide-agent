# ============================================================
# Python 虚拟环境（仅保留目录结构）
# ============================================================
langgraph_env/*
!langgraph_env/.gitkeep
env/
venv/
.venv/

# ============================================================
# 敏感信息 — API Key 等
# ============================================================
.env
*.env
!*.env.example

# ============================================================
# Python 缓存与编译产物
# ============================================================
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# ============================================================
# IDE 与编辑器
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# OS 生成文件
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Claude 内部文件（非项目代码）
# ============================================================
.claude/
CLAUDE.md

# ============================================================
# 参考文档与外部资源（非项目代码）
# ============================================================
old_tools/
old_prompt/

# ============================================================
# 大数据目录（暂不上传内容，仅保留目录结构）
# ============================================================
database/*
!database/.gitkeep
ragbase/chroma_db/

# ============================================================
# 运行产物（自动生成，仅保留目录结构）
# ============================================================
logs/*
!logs/.gitkeep
memory/*/
!memory/.gitkeep
workspace/*
!workspace/.gitkeep

# ============================================================
# Jupyter / Notebook
# ============================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================
# 其他
# ============================================================
*.log
*.tmp
*.bak
*副本*

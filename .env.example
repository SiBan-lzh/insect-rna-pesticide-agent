# Copy this file to .env and fill in your actual API keys and other configuration values.

# ============================================================
# LLM Configuration
# ============================================================
# LLM Provider (openai | anthropic | google)
MODEL_PROVIDER=your_llm_provider
# Model name
MODEL_NAME=model_name
# API Key
API_KEY=sk-your_api_key
# Base URL (not used when MODEL_PROVIDER=google)
BASE_URL=https://api_of_llm_provider.com
# Max output tokens (should be less than the context window size of the model)
MAX_TOKENS=32768

# ============================================================
# Database Paths (If do not use yourself data, please keep the code commented)
# ============================================================
# DATABASE_ROOT=/path/to/database
# INSECT_BLAST_DB=/path/to/blast/insect_blastndb
# INSECT_GFF3_DB=/path/to/annotation/insect_gff3
# INSECT_CDS_DB=/path/to/refseq/insect_cds
# NTO_BLAST_DB=/path/to/blast/nto_blastndb
# NTOS_REFSEQ_DB=/path/to/refseq/nto_refseq
# KINSHIP_DB=/path/to/kinship
# RNASTRUCTURE_HOME=/path/to/RNAstructure
# RAGBASE_ROOT=/path/to/ragbase
# SKILLS_DIR=/path/to/skills
# TOOLS_DIR=/path/to/tools

# ============================================================
# External API Settings (If do not use yourself information, please keep the code commented)
# ============================================================
# PUBMED_EMAIL=your_email@example.com
# PUBMED_API_KEY=your_pubmed_api_key


